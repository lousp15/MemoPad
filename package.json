{
  "name": "memo-pad",
  "version": "0.1.0",
  "private": true,
  "description": "轻量级桌面备忘录 - MemoPad",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "dev:web": "vite --mode web",
    "build": "vite build",
    "build:web": "vite build --mode web",
    "build:installer": "vite build && electron-builder --win --x64",
    "cap:init": "npx cap init MemoPad com.memopad.app",
    "cap:add:android": "npx cap add android",
    "cap:sync": "npx cap sync",
    "cap:build:android": "npm run build:web && npx cap sync && npx cap open android",
    "preview": "vite preview",
    "lint": "eslint src/ --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check:deps": "pnpm ls --depth=0",
    "ci": "pnpm check:deps && pnpm lint && pnpm typecheck && pnpm test"
  },
  "dependencies": {
    "@mui/material": "6.0.0",
    "@mui/x-date-pickers": "7.0.0",
    "@mui/icons-material": "6.0.0",
    "@emotion/react": "^11.13.0",
    "@emotion/styled": "^11.13.0",
    "dayjs": "^1.11.10",
    "dexie": "^4.0.0",
    "octokit": "^3.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "zustand": "^4.5.0",
    "uuid": "^9.0.0",
    "electron-store": "^9.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@capacitor/android": "^6.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^9.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "playwright": "^1.40.0",
    "prettier": "^3.2.0",
    "typescript": "^5.4.0",
    "vite": "^5.4.0",
    "vite-plugin-electron": "^0.28.0",
    "vite-plugin-electron-renderer": "^0.14.0",
    "vitest": "^1.6.0"
  }
}
